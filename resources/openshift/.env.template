# OpenShift Contact Management Deployment Configuration
# Copy this file to .env and fill in the values

# ============================================
# Container Registry Credentials
# ============================================
# GitHub Container Registry (for microservice image)
GH_CR_SERVER=ghcr.io
GH_CR_USERNAME=your-github-username
GH_CR_PASSWORD=your-github-token

# ============================================
# Database Configuration
# ============================================
DB_SERVER_NAME=postgres
DB_PORT=5432
DB_DATABASE_NAME=demo
DB_USERNAME=postgres
DB_PASSWORD=your-secure-password

# ============================================
# Microservice Admin Configuration
# ============================================
ADMIN_PASSWORD=your-admin-password

# ============================================
# IBM Event Streams Configuration
# ============================================
ES_BOOTSTRAP_URL=your-event-streams-bootstrap-url
ES_USERNAME=your-es-username
ES_PASSWORD=your-es-password
ES_TRUSTSTORE_PASSWORD=your-es-truststore-password
ES_TRUSTSTORE_LOCATION=/path/to/es-cert.p12

# ============================================
# Event Endpoint Management Configuration
# ============================================
EEM_BOOTSTRAP_URL=your-eem-bootstrap-url
EEM_USERNAME=your-eem-username
EEM_PASSWORD=your-eem-password
EEM_TRUSTSTORE_PASSWORD=your-eem-truststore-password
EEM_TRUSTSTORE_LOCATION=/path/to/eem-cert.jks

# ============================================
# IWHI Control Plane Registration
# ============================================
SAG_IS_CLOUD_REGISTER_URL=your-cloud-register-url
SAG_IS_EDGE_CLOUD_ALIAS=your-edge-cloud-alias
SAG_IS_CLOUD_REGISTER_TOKEN=your-cloud-register-token
